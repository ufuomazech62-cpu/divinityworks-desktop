# =====================================================================
# Divinity Works backend — environment template
# Copy to `.env` (gitignored). NEVER commit real values.
# In production these are injected by GitHub Actions / Cloudflare
# Secrets Store — not stored in the repo.
# =====================================================================

# ---- LLM (OpenRouter, OpenAI-compatible) ----
PROVIDER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PROVIDER_BASE_URL=https://openrouter.ai/api/v1
PROVIDER_DEFAULT_MODEL=tencent/hy3:free
PROVIDER_COPILOT_MODEL=tencent/hy3:free

# ---- Database ----
MONGODB_CONNECTION_STRING=mongodb://mongo:27017/divinityworks

# ---- Auth (Auth0 + Google social — zero code change vs Rowboat) ----
USE_AUTH=true
AUTH0_SECRET=replace-with-a-long-random-string
AUTH0_BASE_URL=https://api.divinityworks.ai
AUTH0_ISSUER_BASE_URL=https://YOUR-TENANT.us.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
# Your Google OAuth client (plugged into Auth0's Google social connection):
GOOGLE_CLIENT_ID=1026397293465-q976hlpujmnve6v2v1kpppuo4uqklsd4.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# ---- Cache / pub-sub / quotas ----
REDIS_URL=redis://redis:6379

# ---- Vector store (RAG) ----
USE_RAG=true
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=replace-with-qdrant-key

# ---- File storage: Cloudflare R2 (S3-compatible) ----
USE_RAG_UPLOADS=true
USE_RAG_S3_UPLOADS=true
R2_ACCOUNT_ID=a228dff517bf5bb1aa84429e6ad4d9fe
R2_ACCESS_KEY_ID=replace-with-r2-access-key
R2_SECRET_ACCESS_KEY=replace-with-r2-secret
R2_BUCKET=divinityworks-uploads

# ---- Billing (Stripe) — off (guest mode) until you wire it ----
USE_BILLING=false
BILLING_API_URL=
BILLING_API_KEY=

# ---- Misc ----
MAX_QUERIES_PER_MINUTE=60
MAX_PROJECTS_PER_USER=10
USE_CHAT_WIDGET=false

# ---- Cloudflare Tunnel (the ONLY public ingress) ----
# Token is produced by `cloudflared tunnel create` — paste the
# long token string here (or set as a CI secret).
CLOUDFLARED_TUNNEL_TOKEN=
