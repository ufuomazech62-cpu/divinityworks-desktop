{
  "name": "web-bridge",
  "version": "0.1.0",
  "description": "WebSocket bridge server for Divinity Works Electron app",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "ws": "^8.16.0",
    "@x/core": "workspace:*",
    "@x/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "@types/ws": "^8.18.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}